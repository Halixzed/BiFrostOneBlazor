@page "/settings"
@page "/settings/d/{DeviceKey}"
@rendermode InteractiveServer
@using BlazorThreeJS.Maths
@using PortfolioApp.Models
@using PortfolioApp.Services
@implements IDisposable
@inject UnitStore Store
@inject WatermarkStore WatermarkStore
@inject ModelFileStore ModelFileStore
@inject DeviceStore DeviceStore
@inject EnvironmentMapStore EnvironmentMapStore
@inject PdfFileStore PdfFileStore
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Settings</PageTitle>

<div class="settings-shell">
    <div class="settings-header">
        <h1>Add / Remove Model Units</h1>
        <a class="icon-btn icon-btn-primary" href="@_viewerUrl" data-enhance-nav="false" title="Back to viewer" aria-label="Back to viewer">
            <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8" />
            </svg>
        </a>
    </div>

    <p class="units-hint">Shared across every display - editing a unit here changes it everywhere it's selected.</p>

    <div class="table-toolbar">
        <button class="icon-btn icon-btn-add" title="Add unit" aria-label="Add unit" @onclick="StartAdd">
            <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2" />
            </svg>
        </button>
    </div>

    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Model file</th>
                    <th>Zones</th>
                    <th>Width/zone</th>
                    <th>Height</th>
                    <th>Avg. power</th>
                    <th>Warranty</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var unit in Store.GetAll())
                {
                    <tr>
                        <td>@unit.Name</td>
                        <td>@(string.IsNullOrWhiteSpace(unit.ModelUrl) ? "-" : unit.ModelFileName ?? "model.glb")</td>
                        <td>@unit.Zones</td>
                        <td>@unit.WidthPerZone m</td>
                        <td>@unit.Height m</td>
                        <td>@unit.AveragePowerUsage kWh</td>
                        <td>@unit.WarrantyYears years</td>
                        <td class="text-end">
                            <button class="icon-btn icon-btn-primary" title="Edit" aria-label="Edit" @onclick="() => StartEdit(unit)">
                                <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
                                    <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.5 2.207 1.171 10.536a1.5 1.5 0 0 0-.397.716l-.83 3.108a.5.5 0 0 0 .61.61l3.109-.83a1.5 1.5 0 0 0 .716-.397zm-9.5 8.98L8 10.5 5.5 8l-4.146 4.146a.5.5 0 0 0-.146.354z" />
                                </svg>
                            </button>
                            <button class="icon-btn icon-btn-danger" title="Delete" aria-label="Delete" @onclick="() => DeleteUnit(unit)">
                                <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
                                    <path d="M5.5 5.5a.5.5 0 0 1 1 0v6a.5.5 0 0 1-1 0zm2.5 0a.5.5 0 0 1 1 0v6a.5.5 0 0 1-1 0zm3 0a.5.5 0 0 1 1 0v6a.5.5 0 0 1-1 0z" />
                                    <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z" />
                                </svg>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (_editing is not null)
    {
        <EditForm Model="_editing" OnSubmit="Save" class="edit-form">
            <div class="mb-2">
                <label for="unit-name">Name</label>
                <input id="unit-name" class="form-control" @bind="_editing.Name" />
            </div>
            <div class="mb-2">
                <label>Model file (.glb / .gltf)</label>
                @if (!string.IsNullOrWhiteSpace(_editing.ModelUrl))
                {
                    <div class="model-file-current">
                        <span>@(_editing.ModelFileName ?? "model.glb")</span>
                        <label class="icon-btn icon-btn-primary" title="Replace" aria-label="Replace">
                            <InputFile OnChange="OnModelFileSelected" accept=".glb,.gltf,model/gltf-binary,model/gltf+json" hidden />
                            <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
                                <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.5 2.207 1.171 10.536a1.5 1.5 0 0 0-.397.716l-.83 3.108a.5.5 0 0 0 .61.61l3.109-.83a1.5 1.5 0 0 0 .716-.397zm-9.5 8.98L8 10.5 5.5 8l-4.146 4.146a.5.5 0 0 0-.146.354z" />
                            </svg>
                        </label>
                        <button type="button" class="icon-btn icon-btn-danger" title="Remove" aria-label="Remove" @onclick="RemoveModelFile">
                            <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
                                <path d="M5.5 5.5a.5.5 0 0 1 1 0v6a.5.5 0 0 1-1 0zm2.5 0a.5.5 0 0 1 1 0v6a.5.5 0 0 1-1 0zm3 0a.5.5 0 0 1 1 0v6a.5.5 0 0 1-1 0z" />
                                <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z" />
                            </svg>
                        </button>
                    </div>
                }
                else
                {
                    <label class="model-file-upload">
                        <InputFile OnChange="OnModelFileSelected" accept=".glb,.gltf,model/gltf-binary,model/gltf+json" hidden />
                        <span>Upload a .glb or .gltf file</span>
                    </label>
                }
                @if (_modelFileError is not null)
                {
                    <p class="text-danger">@_modelFileError</p>
                }
            </div>
            <div class="mb-2">
                <label>"Learn More" PDF</label>
                @if (!string.IsNullOrWhiteSpace(_editing.PdfUrl))
                {
                    <div class="model-file-current">
                        <span>@(_editing.PdfFileName ?? "document.pdf")</span>
                        <label class="icon-btn icon-btn-primary" title="Replace" aria-label="Replace">
                            <InputFile OnChange="OnPdfFileSelected" accept=".pdf,application/pdf" hidden />
                            <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
                                <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.5 2.207 1.171 10.536a1.5 1.5 0 0 0-.397.716l-.83 3.108a.5.5 0 0 0 .61.61l3.109-.83a1.5 1.5 0 0 0 .716-.397zm-9.5 8.98L8 10.5 5.5 8l-4.146 4.146a.5.5 0 0 0-.146.354z" />
                            </svg>
                        </label>
                        <button type="button" class="icon-btn icon-btn-danger" title="Remove" aria-label="Remove" @onclick="RemovePdfFile">
                            <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
                                <path d="M5.5 5.5a.5.5 0 0 1 1 0v6a.5.5 0 0 1-1 0zm2.5 0a.5.5 0 0 1 1 0v6a.5.5 0 0 1-1 0zm3 0a.5.5 0 0 1 1 0v6a.5.5 0 0 1-1 0z" />
                                <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z" />
                            </svg>
                        </button>
                    </div>
                }
                else
                {
                    <label class="model-file-upload">
                        <InputFile OnChange="OnPdfFileSelected" accept=".pdf,application/pdf" hidden />
                        <span>Upload a PDF for the "Learn More" button</span>
                    </label>
                }
                @if (_pdfFileError is not null)
                {
                    <p class="text-danger">@_pdfFileError</p>
                }
            </div>
            <div class="mb-2">
                <label for="unit-zones">Zones</label>
                <input id="unit-zones" class="form-control" type="number" step="1" min="0" @bind="_editing.Zones" />
            </div>
            <div class="mb-2">
                <label for="unit-width-per-zone">Width per zone (m)</label>
                <input id="unit-width-per-zone" class="form-control" type="number" step="1" min="0" @bind="_editing.WidthPerZone" />
            </div>
            <div class="mb-2">
                <label for="unit-height">Height (m)</label>
                <input id="unit-height" class="form-control" type="number" step="1" min="0" @bind="_editing.Height" />
            </div>
            <div class="mb-2">
                <label for="unit-power">Average power usage (kWh)</label>
                <input id="unit-power" class="form-control" type="number" step="1" min="0" @bind="_editing.AveragePowerUsage" />
            </div>
            <div class="mb-2">
                <label for="unit-warranty">Warranty life (years)</label>
                <input id="unit-warranty" class="form-control" type="number" step="1" min="0" @bind="_editing.WarrantyYears" />
            </div>
            <button type="submit" class="btn btn-success">Save</button>
            <button type="button" class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
        </EditForm>
    }

    <div class="device-section">
        <h1>Displays</h1>
        <p class="units-hint">
            Each display is fully independent - its on-screen unit, background color, watermark,
            and HDRI only affect that one screen.
        </p>

        <div class="device-picker">
            <select class="form-select device-select" @onchange="OnDeviceSwitch">
                @foreach (var d in _devices)
                {
                    <option value="@d.Key" selected="@(d.Id == _device.Id)">@d.DisplayName (@d.Key)</option>
                }
            </select>
            <button type="button" class="icon-btn icon-btn-add" title="Add display" aria-label="Add display" @onclick="() => _addingDevice = !_addingDevice">
                <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2" />
                </svg>
            </button>
            @if (_device.Key != "default")
            {
                <button type="button" class="icon-btn icon-btn-danger" title="Delete this display" aria-label="Delete this display" @onclick="DeleteCurrentDevice">
                    <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
                        <path d="M5.5 5.5a.5.5 0 0 1 1 0v6a.5.5 0 0 1-1 0zm2.5 0a.5.5 0 0 1 1 0v6a.5.5 0 0 1-1 0zm3 0a.5.5 0 0 1 1 0v6a.5.5 0 0 1-1 0z" />
                        <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z" />
                    </svg>
                </button>
            }
        </div>

        @if (_addingDevice)
        {
            <div class="add-device-form">
                <div class="mb-2">
                    <label for="new-device-key">URL key (e.g. "lobby-1")</label>
                    <input id="new-device-key" class="form-control" @bind="_newDeviceKey" />
                </div>
                <div class="mb-2">
                    <label for="new-device-name">Display name</label>
                    <input id="new-device-name" class="form-control" @bind="_newDeviceName" />
                </div>
                @if (_addDeviceError is not null)
                {
                    <p class="text-danger">@_addDeviceError</p>
                }
                <button type="button" class="btn btn-success" @onclick="CreateDevice">Create</button>
                <button type="button" class="btn btn-secondary" @onclick="() => _addingDevice = false">Cancel</button>
            </div>
        }

        <div class="mb-2 device-rename">
            <label for="device-name">Display name</label>
            <input id="device-name" class="form-control" value="@_device.DisplayName" @onchange="OnRenameDevice" />
        </div>
    </div>

    <div class="watermark-section">
        <h1>Now Showing</h1>
        <select class="form-select active-unit-select" @onchange="OnActiveUnitChanged">
            <option value="" selected="@(_device.ActiveUnitId is null)">None</option>
            @foreach (var unit in Store.GetAll())
            {
                <option value="@unit.Id" selected="@(_device.ActiveUnitId == unit.Id)">@unit.Name</option>
            }
        </select>
    </div>

    <div class="watermark-section">
        <h1>Background Watermark</h1>

        @if (_watermark is not null)
        {
            <div class="watermark-preview">
                <img class="@(_watermark.Grayscale ? "grayscale" : "")" src="@WatermarkStore.Url(_watermark)" alt="@_watermark.OriginalFileName" />
                <div class="watermark-preview-info">
                    <span>@_watermark.OriginalFileName</span>
                    <label class="watermark-grayscale-toggle">
                        <input type="checkbox" checked="@_watermark.Grayscale" @onchange="OnGrayscaleToggled" />
                        Grayscale
                    </label>
                    <div class="watermark-preview-actions">
                        <label class="icon-btn icon-btn-primary" title="Replace" aria-label="Replace">
                            <InputFile OnChange="OnWatermarkFileSelected" accept=".png,.svg,image/png,image/svg+xml" hidden />
                            <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
                                <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.5 2.207 1.171 10.536a1.5 1.5 0 0 0-.397.716l-.83 3.108a.5.5 0 0 0 .61.61l3.109-.83a1.5 1.5 0 0 0 .716-.397zm-9.5 8.98L8 10.5 5.5 8l-4.146 4.146a.5.5 0 0 0-.146.354z" />
                            </svg>
                        </label>
                        <button class="icon-btn icon-btn-danger" title="Delete" aria-label="Delete" @onclick="DeleteWatermark">
                            <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
                                <path d="M5.5 5.5a.5.5 0 0 1 1 0v6a.5.5 0 0 1-1 0zm2.5 0a.5.5 0 0 1 1 0v6a.5.5 0 0 1-1 0zm3 0a.5.5 0 0 1 1 0v6a.5.5 0 0 1-1 0z" />
                                <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
        }
        else
        {
            <label class="watermark-upload">
                <InputFile OnChange="OnWatermarkFileSelected" accept=".png,.svg,image/png,image/svg+xml" hidden />
                <span>Upload a logo (PNG or SVG) to display as a faded background watermark on the viewer.</span>
            </label>
        }

        @if (_watermarkError is not null)
        {
            <p class="text-danger">@_watermarkError</p>
        }
    </div>

    <div class="watermark-section">
        <h1>Background Color</h1>
        <label class="background-color-picker">
            <input type="color" @ref="_colorPickerElement" value="@_device.BackgroundColor" @oninput="OnBackgroundColorChanged" />
            <span>@_device.BackgroundColor</span>
        </label>
    </div>

    <div class="watermark-section">
        <h1>Environment Map (HDRI)</h1>
        <p class="environment-map-hint">
            Adds image-based ambient/reflection lighting from an uploaded equirectangular JPG/PNG
            on top of the built-in studio lights (doesn't replace them). Not a true HDR pipeline
            (no .hdr/.exr support, no roughness-based reflection blur), but real image-based
            lighting rather than a flat gradient.
        </p>

        @if (_environmentMap is not null)
        {
            <div class="watermark-preview">
                <img src="@EnvironmentMapStore.Url(_environmentMap)" alt="@_environmentMap.OriginalFileName" />
                <div class="watermark-preview-info">
                    <span>@_environmentMap.OriginalFileName</span>
                    <div class="watermark-preview-actions">
                        <label class="icon-btn icon-btn-primary" title="Replace" aria-label="Replace">
                            <InputFile OnChange="OnEnvironmentMapFileSelected" accept=".jpg,.jpeg,.png,image/jpeg,image/png" hidden />
                            <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
                                <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.5 2.207 1.171 10.536a1.5 1.5 0 0 0-.397.716l-.83 3.108a.5.5 0 0 0 .61.61l3.109-.83a1.5 1.5 0 0 0 .716-.397zm-9.5 8.98L8 10.5 5.5 8l-4.146 4.146a.5.5 0 0 0-.146.354z" />
                            </svg>
                        </label>
                        <button class="icon-btn icon-btn-danger" title="Delete" aria-label="Delete" @onclick="DeleteEnvironmentMap">
                            <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
                                <path d="M5.5 5.5a.5.5 0 0 1 1 0v6a.5.5 0 0 1-1 0zm2.5 0a.5.5 0 0 1 1 0v6a.5.5 0 0 1-1 0zm3 0a.5.5 0 0 1 1 0v6a.5.5 0 0 1-1 0z" />
                                <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
        }
        else
        {
            <label class="watermark-upload">
                <InputFile OnChange="OnEnvironmentMapFileSelected" accept=".jpg,.jpeg,.png,image/jpeg,image/png" hidden />
                <span>Upload an equirectangular JPG or PNG to light the viewer with image-based lighting instead of the studio light rig.</span>
            </label>
        }

        @if (_environmentMapError is not null)
        {
            <p class="text-danger">@_environmentMapError</p>
        }
    </div>
</div>

@code {
    [Parameter]
    public string? DeviceKey { get; set; }

    private Device _device = null!;
    private IReadOnlyList<Device> _devices = Array.Empty<Device>();
    private string _viewerUrl = "/";

    private bool _addingDevice;
    private string _newDeviceKey = "";
    private string _newDeviceName = "";
    private string? _addDeviceError;

    private Unit? _editing;
    private bool _isNew;

    // The unit's ModelUrl as it was when editing began, so Save/Cancel know which physical file
    // (if any) was superseded and needs cleaning up.
    private string? _originalModelUrl;
    private string? _modelFileError;

    // Same idea as _originalModelUrl, but for the "Learn More" PDF.
    private string? _originalPdfUrl;
    private string? _pdfFileError;

    private Watermark? _watermark;
    private string? _watermarkError;

    private ElementReference _colorPickerElement;
    private DotNetObjectReference<Settings>? _colorPickerDotNetRef;

    private EnvironmentMap? _environmentMap;
    private string? _environmentMapError;

    protected override void OnInitialized()
    {
        _device = DeviceStore.GetOrCreateByKey(DeviceKey ?? "default");
        _devices = DeviceStore.GetAll();
        _viewerUrl = DeviceKey is null ? "/" : $"/d/{DeviceKey}";

        Store.Changed += OnUnitsChanged;
        WatermarkStore.Changed += OnWatermarkStoreChanged;
        _watermark = WatermarkStore.Get(_device.Id);

        DeviceStore.Changed += OnDeviceStoreChanged;

        EnvironmentMapStore.Changed += OnEnvironmentMapStoreChanged;
        _environmentMap = EnvironmentMapStore.Get(_device.Id);
    }

    private void OnDeviceSwitch(ChangeEventArgs e)
    {
        var key = (string)e.Value!;
        Nav.NavigateTo(key == "default" ? "/settings" : $"/settings/d/{key}", forceLoad: true);
    }

    private void CreateDevice()
    {
        _addDeviceError = null;
        var key = _newDeviceKey.Trim().ToLowerInvariant().Replace(' ', '-');
        if (string.IsNullOrEmpty(key))
        {
            _addDeviceError = "Enter a URL key for the new display.";
            return;
        }

        if (_devices.Any(d => d.Key == key))
        {
            _addDeviceError = "A display with that key already exists.";
            return;
        }

        var device = DeviceStore.GetOrCreateByKey(key);
        if (!string.IsNullOrWhiteSpace(_newDeviceName))
        {
            DeviceStore.Rename(device.Id, _newDeviceName.Trim());
        }

        Nav.NavigateTo($"/settings/d/{key}", forceLoad: true);
    }

    private void DeleteCurrentDevice()
    {
        var deviceId = _device.Id;
        if (DeviceStore.Delete(deviceId))
        {
            // Watermark/EnvironmentMap rows aren't cascade-deleted at the DB level (DeviceId is a
            // plain column, not an EF-configured FK), so they'd otherwise be orphaned along with
            // their physical files.
            WatermarkStore.Delete(deviceId);
            EnvironmentMapStore.Delete(deviceId);
            Nav.NavigateTo("/settings", forceLoad: true);
        }
    }

    private void OnRenameDevice(ChangeEventArgs e)
    {
        DeviceStore.Rename(_device.Id, (string)e.Value!);
    }

    private void OnActiveUnitChanged(ChangeEventArgs e)
    {
        var value = (string?)e.Value;
        int? unitId = string.IsNullOrEmpty(value) ? null : int.Parse(value);
        DeviceStore.SetActiveUnit(_device.Id, unitId);
    }

    private void OnDeviceStoreChanged(int deviceId)
    {
        if (deviceId != _device.Id)
        {
            return;
        }

        InvokeAsync(() =>
        {
            _device = DeviceStore.GetById(_device.Id) ?? _device;
            _devices = DeviceStore.GetAll();
            StateHasChanged();
        });
    }

