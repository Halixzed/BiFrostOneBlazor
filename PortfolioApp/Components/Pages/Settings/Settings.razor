    private const long MaxModelFileSize = 50 * 1024 * 1024;

    private void StartAdd()
    {
        _editing = new Unit { Name = "new-unit" };
        _originalModelUrl = null;
        _modelFileError = null;
        _originalPdfUrl = null;
        _pdfFileError = null;
        _isNew = true;
    }

    private void StartEdit(Unit unit)
    {
        _editing = new Unit
        {
            Id = unit.Id,
            Name = unit.Name,
            Rotation = new Vector3(unit.Rotation.X, unit.Rotation.Y, unit.Rotation.Z),
            ModelUrl = unit.ModelUrl,
            ModelFileName = unit.ModelFileName,
            PdfUrl = unit.PdfUrl,
            PdfFileName = unit.PdfFileName,
            Zones = unit.Zones,
            WidthPerZone = unit.WidthPerZone,
            Height = unit.Height,
            AveragePowerUsage = unit.AveragePowerUsage,
            WarrantyYears = unit.WarrantyYears,
        };
        _originalModelUrl = unit.ModelUrl;
        _modelFileError = null;
        _originalPdfUrl = unit.PdfUrl;
        _pdfFileError = null;
        _isNew = false;
    }

    private async Task OnModelFileSelected(InputFileChangeEventArgs e)
    {
        if (_editing is null)
        {
            return;
        }

        _modelFileError = null;
        var file = e.File;
        var extension = Path.GetExtension(file.Name).ToLowerInvariant();

        if (extension != ".glb" && extension != ".gltf")
        {
            _modelFileError = "Only GLB or GLTF files are supported.";
            return;
        }

        if (file.Size > MaxModelFileSize)
        {
            _modelFileError = "File is too large (max 50 MB).";
            return;
        }

        try
        {
            // If this edit session already uploaded a replacement earlier (before saving), that
            // intermediate file is about to be superseded again and would otherwise be orphaned.
            if (_editing.ModelUrl is not null && _editing.ModelUrl != _originalModelUrl)
            {
                ModelFileStore.DeleteByUrl(_editing.ModelUrl);
            }

            await using var stream = file.OpenReadStream(MaxModelFileSize);
            _editing.ModelUrl = await ModelFileStore.SaveAsync(file.Name, stream);
            _editing.ModelFileName = file.Name;
        }
        catch (Exception ex)
        {
            _modelFileError = $"Upload failed: {ex.Message}";
        }
    }

    private void RemoveModelFile()
    {
        if (_editing is null)
        {
            return;
        }

        // The original file (if any) is only actually deleted on Save/Cancel, once we know
        // whether this edit is being committed or discarded.
        _editing.ModelUrl = null;
        _editing.ModelFileName = null;
    }

    private const long MaxPdfFileSize = 20 * 1024 * 1024;

    private async Task OnPdfFileSelected(InputFileChangeEventArgs e)
    {
        if (_editing is null)
        {
            return;
        }

        _pdfFileError = null;
        var file = e.File;
        var extension = Path.GetExtension(file.Name).ToLowerInvariant();

        if (extension != ".pdf")
        {
            _pdfFileError = "Only PDF files are supported.";
            return;
        }

        if (file.Size > MaxPdfFileSize)
        {
            _pdfFileError = "File is too large (max 20 MB).";
            return;
        }

        try
        {
            if (_editing.PdfUrl is not null && _editing.PdfUrl != _originalPdfUrl)
            {
                PdfFileStore.DeleteByUrl(_editing.PdfUrl);
            }

            await using var stream = file.OpenReadStream(MaxPdfFileSize);
            _editing.PdfUrl = await PdfFileStore.SaveAsync(file.Name, stream);
            _editing.PdfFileName = file.Name;
        }
        catch (Exception ex)
        {
            _pdfFileError = $"Upload failed: {ex.Message}";
        }
    }

    private void RemovePdfFile()
    {
        if (_editing is null)
        {
            return;
        }

        _editing.PdfUrl = null;
        _editing.PdfFileName = null;
    }

    private void Save()
    {
        if (_editing is null)
        {
            return;
        }

        if (_isNew)
        {
            Store.Add(_editing);
        }
        else
        {
            Store.Update(_editing);
        }

        if (_originalModelUrl is not null && _originalModelUrl != _editing.ModelUrl)
        {
            ModelFileStore.DeleteByUrl(_originalModelUrl);
        }

        if (_originalPdfUrl is not null && _originalPdfUrl != _editing.PdfUrl)
        {
            PdfFileStore.DeleteByUrl(_originalPdfUrl);
        }

        _editing = null;
    }

    private void CancelEdit()
    {
        if (_editing is not null && _editing.ModelUrl is not null && _editing.ModelUrl != _originalModelUrl)
        {
            // A new file was uploaded this session but never saved to a unit - clean it up.
            ModelFileStore.DeleteByUrl(_editing.ModelUrl);
        }

        if (_editing is not null && _editing.PdfUrl is not null && _editing.PdfUrl != _originalPdfUrl)
        {
            PdfFileStore.DeleteByUrl(_editing.PdfUrl);
        }

        _editing = null;
    }

    private void DeleteUnit(Unit unit)
    {
        ModelFileStore.DeleteByUrl(unit.ModelUrl);
        PdfFileStore.DeleteByUrl(unit.PdfUrl);
        Store.Delete(unit.Id);
    }

    public void Dispose()
    {
        Store.Changed -= OnUnitsChanged;
        WatermarkStore.Changed -= OnWatermarkStoreChanged;
        DeviceStore.Changed -= OnDeviceStoreChanged;
        EnvironmentMapStore.Changed -= OnEnvironmentMapStoreChanged;
        _colorPickerDotNetRef?.Dispose();
    }
}
